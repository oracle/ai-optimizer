# Copy to .env.pytest at the repo root to enable live OCI integration tests.
# Shell environment variables win over this file (override=False) so CI can
# pass values directly without editing.

# Required to enable live_oci tests:
AIO_GENAI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIO_GENAI_REGION=us-chicago-1

# Optional — override the OCI auth profile name (defaults to DEFAULT from ~/.oci/config):
# OCI_CLI_PROFILE=DEFAULT
