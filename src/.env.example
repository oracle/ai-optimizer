## Authentication
AIO_API_KEY="example_api_key"

## Database (DB_* env vars take precedence over AIO_DB_*)
# AIO_DB_USERNAME=
# AIO_DB_PASSWORD=
# AIO_DB_DSN=
# AIO_DB_WALLET_PASSWORD=
# AIO_DB_POOL_SIZE=5

## Logging
# AIO_LOG_LEVEL=INFO

## Server
# AIO_SERVER_URL=
# AIO_SERVER_URL_PREFIX=
# AIO_SERVER_PORT=8000
# AIO_SERVER_SSL=false
# AIO_SERVER_SSL_CERT_FILE=
# AIO_SERVER_SSL_KEY_FILE=
# AIO_MAX_CLIENTS=64

## OCI CLI overrides (applied to DEFAULT profile; OCI_CLI_* env vars take precedence)
## See: https://docs.oracle.com/en-us/iaas/Content/API/SDKDocs/clienvironmentvariables.htm
# AIO_OCI_CLI_AUTH=api_key
# AIO_OCI_CLI_TENANCY=
# AIO_OCI_CLI_REGION=
# AIO_OCI_CLI_USER=
# AIO_OCI_CLI_FINGERPRINT=
# AIO_OCI_CLI_KEY_FILE=
# AIO_OCI_CLI_KEY_CONTENT=
# AIO_OCI_CLI_PASSPHRASE=
# AIO_OCI_CLI_SECURITY_TOKEN_FILE=

## OCI GenAI
# AIO_GENAI_COMPARTMENT_ID=
# AIO_GENAI_REGION=

## Model Overrides
# AIO_COHERE_API_KEY=
# AIO_OPENAI_API_KEY=
# AIO_PPLX_API_KEY=
# AIO_ON_PREM_OLLAMA_URL="http://127.0.0.1:11434"
# AIO_ON_PREM_HF_URL="http://127.0.0.1:8080"
# AIO_ON_PREM_VLLM_URL="http://localhost:8000/v1"

## Client
# AIO_CLIENT_ADDRESS=localhost
# AIO_CLIENT_URL_PREFIX=
# AIO_CLIENT_PORT=8051
# AIO_CLIENT_COOKIE_SECRET=
# AIO_CLIENT_SSL=false
# AIO_CLIENT_SSL_CERT_FILE=
# AIO_CLIENT_SSL_KEY_FILE=
