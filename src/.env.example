## Authentication
# AIO_API_KEY=

## CORE database
# AIO_DB_USERNAME=
# AIO_DB_PASSWORD=
# AIO_DB_DSN=

## Common model providers
# AIO_OPENAI_API_KEY=
# AIO_ON_PREM_OLLAMA_URL=http://127.0.0.1:11434
