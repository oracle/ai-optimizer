  "title": "AI Optimizer \u2014 Overview",
  "uploadedGrafana": false,
  "variables": {},
  "version": "v5",
  "widgets": [
    {
      "description": "Server-side request rate, grouped by FastAPI route. Counts spans named 'http POST /...' produced by FastAPIInstrumentor.",
      "fillSpans": false,
      "id": "panel-request-rate",
      "isStacked": false,
      "nullZeroValues": "zero",
      "opacity": "1",
      "panelTypes": "graph",
      "query": {
        "builder": {
          "queryData": [
            {
              "aggregations": [
                {
                  "expression": "rate(name)"
                }
              ],
              "dataSource": "traces",
              "disabled": false,
              "expression": "A",
              "filter": {
                "expression": "service.name = 'ai-optimizer-server' AND kind = 2 AND http.route EXISTS"
              },
              "groupBy": [
                {
                  "dataType": "string",
                  "isColumn": false,
                  "key": "http.route",
                  "type": "tag"
                }
              ],
              "having": {
                "expression": ""
              },
              "legend": "{{http.route}}",
              "orderBy": [],
              "queryName": "A",
              "stepInterval": 60
            }
          ],
          "queryFormulas": []
        },
        "clickhouse_sql": [],
        "promql": [],
        "queryType": "builder"
      },
      "thresholds": [],
      "title": "Request rate (by route)",
      "yAxisUnit": "reqps"
    },
    {
      "description": "95th-percentile server-side latency per route. Aggregates p95 of duration_nano (column rename in SigNoz 0.121).",
